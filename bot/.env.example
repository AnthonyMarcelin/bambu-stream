# Twitch bot credentials.
# TWITCH_BOT_USERNAME can be your channel account or a dedicated bot account.
# Get an OAuth token (format oauth:xxxx) at https://twitchtokengenerator.com
# with the chat:read and chat:edit scopes.
TWITCH_BOT_USERNAME=3dprint33
TWITCH_OAUTH_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CHANNEL=3dprint33
# Optional: pin a model, e.g. claude-haiku-4-5-20251001. Leave blank for default.
CLAUDE_MODEL=
# Optional: reminder interval in minutes (default 10)
REMINDER_MIN=10
